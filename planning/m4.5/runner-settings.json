{
    "//": "Loaded by launch-run.sh via --settings. Scopes the worker sandbox to the runner launch and propagates to worker subagents (verified: --settings hooks reach isolation:worktree subagents). The PreToolUse hook enforces the per-phase write allowlist for worktree writes and the Bash/Read deny-list; the permissions.deny array is a native backstop.",
    "permissions": {
        "deny": [
            "Bash(git push:*)",
            "Bash(git remote:*)",
            "Bash(git config:*)",
            "Bash(gh auth:*)",
            "Bash(rm -rf:*)",
            "Bash(rm -fr:*)",
            "Bash(env)",
            "Bash(printenv:*)",
            "Read(//Users/*/.ssh/**)",
            "Read(//Users/*/.config/gh/**)",
            "Read(//Users/*/.netrc)",
            "Read(//Users/*/.aws/**)",
            "Write(//Users/*/.ssh/**)",
            "Write(//Users/*/.aws/**)",
            "Write(//Users/*/.netrc)",
            "Write(//Users/*/.config/**)",
            "Write(//Users/*/.claude/**)",
            "Write(//Users/*/.zshrc)",
            "Write(//Users/*/.bashrc)",
            "Write(//Users/*/.zprofile)",
            "Write(//Users/*/.bash_profile)"
        ]
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash planning/m4.5/hooks/sandbox.sh"
                    }
                ]
            }
        ]
    }
}
